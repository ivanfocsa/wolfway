---
import { mainNav } from '@/content/navigation';
import Button from '@/components/Button.astro';
---

<header id="site-header" class="fixed top-0 left-0 z-50 w-full transition-all duration-300 py-3 lg:py-4">
  <nav class="mx-auto max-w-7xl px-5 lg:px-10">
    <div
      id="header-inner"
      class="flex items-center justify-between px-5 py-2 lg:px-6 lg:py-2 transition-all duration-300 bg-navy/35 border border-white/5 backdrop-blur-md rounded-xl shadow-lg"
    >
      <!-- Logo & Brand Name -->
      <a href="/" class="relative z-50 flex items-center gap-2.5 group" aria-label="WolfWay Logistics home">
        <img
          id="header-logo"
          src="/images/logo_icon.png"
          alt="WolfWay Logo"
          class="h-16 w-16 md:h-18 md:w-18 object-contain transition-all duration-300 group-hover:scale-105"
        />
        <span
          id="header-title"
          class="font-heading text-lg md:text-xl font-extrabold uppercase tracking-widest text-white group-hover:text-cyan transition-all duration-300"
        >
          WolfWay
        </span>
      </a>

      <!-- Desktop Nav Links & CTA -->
      <div class="hidden lg:flex items-center gap-7">
        <div class="flex items-center gap-4">
          {mainNav.map((item) => (
            <a
              href={item.href}
              class="text-[11px] font-medium uppercase tracking-[0.2em] text-white/70 hover:text-white px-2 py-1 transition-all duration-300 relative group/link"
            >
              {item.label}
              <span class="absolute bottom-0 left-2 right-2 h-0.5 bg-cyan scale-x-0 group-hover/link:scale-x-100 transition-transform duration-300 origin-center" aria-hidden="true"></span>
            </a>
          ))}
        </div>
        
        <Button
          href="/request-a-quote"
          variant="primary"
          size="sm"
          arrow={true}
          class="group text-xs py-2 px-4"
        >
          Request a Quote
        </Button>
      </div>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-toggle"
        class="relative z-50 flex h-8 w-8 items-center justify-center lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="sr-only">Menu</span>
        <div class="flex flex-col gap-1.5" id="hamburger-icon">
          <span class="block h-0.5 w-5 bg-white transition-all duration-300 origin-center" id="bar-1"></span>
          <span class="block h-0.5 w-5 bg-white transition-all duration-300" id="bar-2"></span>
          <span class="block h-0.5 w-5 bg-white transition-all duration-300 origin-center" id="bar-3"></span>
        </div>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 flex flex-col bg-navy opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
    aria-hidden="true"
  >
    <div class="flex flex-col items-center justify-center flex-1 gap-6 px-6">
      {mainNav.map((item) => (
        <a
          href={item.href}
          class="mobile-nav-link text-2xl font-heading font-semibold uppercase tracking-wider text-white/80 hover:text-white transition-colors duration-200"
        >
          {item.label}
        </a>
      ))}
      <Button
        href="/request-a-quote"
        variant="primary"
        size="lg"
        class="mt-4"
      >
        Request a Quote
      </Button>
    </div>
    <div class="pb-8 text-center text-sm text-steel">
      <a href="tel:+12244464256" class="text-white/60 hover:text-white transition-colors">+1 (224) 446-4256</a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const logo = document.getElementById('header-logo');
  const title = document.getElementById('header-title');
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar-1');
  const bar2 = document.getElementById('bar-2');
  const bar3 = document.getElementById('bar-3');
  let menuOpen = false;

  // Scroll background & scaling
  function onScroll() {
    if (!header) return;
    if (window.scrollY > 40) {
      header.classList.add('header-scrolled');
      logo?.classList.remove('h-16', 'w-16', 'md:h-18', 'md:w-18');
      logo?.classList.add('h-10', 'w-10', 'md:h-12', 'md:w-12');
      title?.classList.remove('text-lg', 'text-xl', 'md:text-xl');
      title?.classList.add('text-base', 'md:text-lg');
    } else {
      header.classList.remove('header-scrolled');
      logo?.classList.add('h-16', 'w-16', 'md:h-18', 'md:w-18');
      logo?.classList.remove('h-10', 'w-10', 'md:h-12', 'md:w-12');
      title?.classList.add('text-lg', 'text-xl', 'md:text-xl');
      title?.classList.remove('text-base', 'md:text-lg');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu
  function openMenu() {
    menuOpen = true;
    menu?.classList.remove('opacity-0', 'pointer-events-none');
    menu?.classList.add('opacity-100', 'pointer-events-auto');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    toggle?.setAttribute('aria-label', 'Close menu');
    bar1?.classList.add('rotate-45', 'translate-y-[4px]');
    bar2?.classList.add('opacity-0');
    bar3?.classList.add('-rotate-45', '-translate-y-[4px]');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menuOpen = false;
    menu?.classList.add('opacity-0', 'pointer-events-none');
    menu?.classList.remove('opacity-100', 'pointer-events-auto');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Open menu');
    bar1?.classList.remove('rotate-45', 'translate-y-[4px]');
    bar2?.classList.remove('opacity-0');
    bar3?.classList.remove('-rotate-45', '-translate-y-[4px]');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    menuOpen ? closeMenu() : openMenu();
  });

  // Close on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) closeMenu();
  });
</script>

<style>
  /* Scroll Capsule Animations */
  #site-header {
    transition: padding 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #header-inner {
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  :global(.header-scrolled) {
    padding-top: 0.5rem !important;
    padding-bottom: 0.5rem !important;
  }
  :global(.header-scrolled) #header-inner {
    background-color: rgba(17, 23, 34, 0.92);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
  }
</style>
