---
// src/components/StatsCounter.astro
---

<section class="relative bg-navy py-14 sm:py-20 lg:py-24 text-white overflow-hidden select-none">
  <div class="relative z-10 mx-auto max-w-7xl px-5 lg:px-10">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12 md:gap-x-12">
      <!-- Stat 1 -->
      <div class="stat-item pt-2 flex flex-col">
        <span class="font-heading text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-none tracking-tight flex items-baseline">
          500<span class="text-cyan font-bold">+</span>
        </span>
        <span class="mt-3 text-[10px] sm:text-xs font-heading font-semibold uppercase tracking-[0.2em] text-steel">
          Loads Delivered
        </span>
      </div>

      <!-- Stat 2 -->
      <div class="stat-item pt-2 flex flex-col">
        <span class="font-heading text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-none tracking-tight flex items-baseline">
          98<span class="text-cyan font-bold">.7%</span>
        </span>
        <span class="mt-3 text-[10px] sm:text-xs font-heading font-semibold uppercase tracking-[0.2em] text-steel">
          On-Time Delivery
        </span>
      </div>

      <!-- Stat 3 -->
      <div class="stat-item pt-2 flex flex-col">
        <span class="font-heading text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-none tracking-tight flex items-baseline">
          24<span class="text-cyan font-bold">/7/365</span>
        </span>
        <span class="mt-3 text-[10px] sm:text-xs font-heading font-semibold uppercase tracking-[0.2em] text-steel">
          Dispatch Coverage
        </span>
      </div>

      <!-- Stat 4 -->
      <div class="stat-item pt-2 flex flex-col">
        <span class="font-heading text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-none tracking-tight flex items-baseline">
          5<span class="text-cyan font-bold">.0★</span>
        </span>
        <span class="mt-3 text-[10px] sm:text-xs font-heading font-semibold uppercase tracking-[0.2em] text-steel">
          Google Rating
        </span>
      </div>
    </div>
  </div>
</section>
