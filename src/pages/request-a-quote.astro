---
import BaseLayout from '@/layouts/BaseLayout.astro';
import QuoteForm from '@/components/QuoteForm.astro';
---

<BaseLayout
  title="Request a Quote | WolfWay Logistics"
  description="Get a competitive freight quote for flatbed, step deck, and open deck transportation."
>
  <!-- Page Header with Geometric Accents -->
  <section class="bg-navy pt-36 pb-20 relative overflow-hidden">
    <!-- Grid line background -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff02_1px,transparent_1px),linear-gradient(to_bottom,#ffffff02_1px,transparent_1px)] bg-[size:3rem_3rem]" aria-hidden="true"></div>
    <!-- Soft glow -->
    <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[400px] h-[400px] bg-cyan/5 rounded-full blur-[120px]" aria-hidden="true"></div>

    <div class="mx-auto max-w-7xl px-5 lg:px-10 relative z-10">
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold uppercase text-white leading-none tracking-tight">
        Request a Freight Quote
      </h1>
      <p class="mt-4 max-w-2xl text-base md:text-lg text-white/60 font-body font-light leading-relaxed">
        Tell us about your shipment and we'll get back to you with a competitive rate within one business day.
      </p>
    </div>
  </section>

  <!-- Form + Sidebar -->
  <section class="bg-offwhite py-20" data-animate="fade-up">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Form Column (Premium container with border highlight) -->
        <div class="lg:col-span-2">
          <div class="bg-white p-8 sm:p-12 border border-steel/10 shadow-sm relative">
            
            <div class="mb-10">
              <h2 class="font-heading text-2xl font-bold uppercase text-ink">
                Shipment Details
              </h2>
              <p class="text-xs text-steel mt-1 font-body">
                Please complete all required fields (*) to ensure an accurate quote.
              </p>
            </div>
            
            <QuoteForm />
          </div>
        </div>

        <!-- Sidebar Contact Info (Premium glassmorphic card) -->
        <aside class="lg:col-span-1">
          <div class="bg-navy p-8 lg:p-10 sticky top-28 border border-white/5 shadow-xl relative overflow-hidden">
            <!-- Glass texture -->
            <div class="absolute inset-0 bg-white/[0.01]" aria-hidden="true"></div>
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-cyan/[0.02] to-transparent" aria-hidden="true"></div>

            <div class="relative z-10">
              <h3 class="font-heading text-2xl font-bold uppercase text-white mb-6 flex items-center gap-2">
                Need it faster?
              </h3>
              <p class="text-white/70 text-sm font-body mb-8 font-light leading-relaxed">
                For urgent shipments, time-sensitive loads, or specialized carrier availability, contact our dispatch office directly.
              </p>

              <!-- Phone -->
              <div class="flex items-center gap-4 mb-8 group">
                <div class="flex-shrink-0 flex items-center justify-center h-10 w-10 text-cyan">
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-widest text-white/45 mb-0.5 font-body">Phone Support</p>
                  <a href="tel:+12244464256" class="text-white hover:text-cyan transition-colors text-lg font-heading font-semibold uppercase tracking-wider">
                    +1 (224) 446-4256
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-center gap-4 mb-10 group">
                <div class="flex-shrink-0 flex items-center justify-center h-10 w-10 text-cyan">
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-widest text-white/45 mb-0.5 font-body">Email Dispatch</p>
                  <a href="mailto:wolfwaylogistics@gmail.com" class="text-white hover:text-cyan transition-colors text-sm font-body font-medium">
                    wolfwaylogistics@gmail.com
                  </a>
                </div>
              </div>

              <!-- Specs Divider -->
              <div class="border-t border-white/10 pt-8 mt-4">
                <h4 class="font-heading text-xs font-bold uppercase tracking-widest text-white/60 mb-4">
                  Open-Deck Capabilities
                </h4>
                <ul class="space-y-3">
                  {['Flatbed Freight', 'Step Deck Transport', 'Open Deck Logistics', 'Oversized Cargo'].map((item) => (
                    <li class="flex items-center gap-3 text-sm text-white/70 font-body font-light">
                      <span class="h-1.5 w-1.5 bg-cyan rounded-full" aria-hidden="true"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
